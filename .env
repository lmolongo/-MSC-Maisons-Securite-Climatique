# ══════ MSC Website — Environment Variables ══════

# Ports
PORT_FRONTEND=80
PORT_FRONTEND_SSL=443

# Backend
NODE_ENV=production
BACKEND_PORT=3000

# PostgreSQL
POSTGRES_DB=msc
POSTGRES_USER=msc
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SMTP — Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@msc-guadeloupe.fr
SMTP_PASS=CHANGE_ME
SMTP_FROM=MSC Guadeloupe <contact@msc-guadeloupe.fr>

# Notification recipient
NOTIFY_EMAIL=contact@msc-guadeloupe.fr

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# Admin dashboard
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
